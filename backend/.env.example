# Backend Environment Variables Template
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to Git - it will be in .gitignore

# Server Configuration
PORT=8080
TCP_PORT=9090

# Node Identity (display name and room)
NICK=anonymous
ROOM=general

# mDNS Discovery Configuration
MDNS_ENABLED=true
DISCOVERY_TAG=meshpulse-default

# Peer-to-Peer Mesh Configuration
P2P_ENABLED=true
SEED_PEERS=

# CORS Configuration - add your frontend URLs here
# Format: http://localhost:3000,https://your-frontend.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# MongoDB Atlas Connection String (REQUIRED - no default)
# Get this from MongoDB Atlas dashboard
# Format: mongodb+srv://username:password@cluster.xxxxx.mongodb.net/offGrid?retryWrites=true&w=majority
# Example: mongodb+srv://user:pass@cluster0.abcde.mongodb.net/offGrid?retryWrites=true&w=majority
MONGO_URI=your_mongodb_atlas_connection_string_here
