# Frontend Environment Variables Template
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to Git - it will be in .gitignore

# API Backend Base URL (without trailing slash)
# Local development: http://localhost:8080
# Production (Render): https://your-backend-service.onrender.com
VITE_API_BASE_URL=http://localhost:8080

# WebSocket Backend Base URL (without trailing slash)
# Local development: http://localhost:8080
# Production (Render): https://your-backend-service.onrender.com
# Note: Browser will auto-upgrade to wss:// for HTTPS origins
VITE_WS_BASE_URL=http://localhost:8080
